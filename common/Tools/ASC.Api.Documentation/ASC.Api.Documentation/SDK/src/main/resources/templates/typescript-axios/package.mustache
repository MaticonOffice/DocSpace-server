{
  "name": "{{packageName}}",
  "version": "{{packageVersion}}",
  "description": "A simple TypeScript SDK for integrating with the Maticon Office DocSpace API",
  "homepage": "https://www.maticonoffice.ru",
  "author": "Maticon Office LLC <integration@maticonoffice.ru> (https://www.maticonoffice.ru)",
  "maintainers": [
    "Maticon Office LLC <integration@maticonoffice.ru> (https://www.maticonoffice.ru)"
  ],
  "repository": {
    "type": "git",
    "url": "git+{{repositoryUrl}}.git"
  },
  "bugs": {
    "url": "{{repositoryUrl}}/issues",
    "email": "support@maticonoffice.ru"
  },
  "keywords": [
    "maticonoffice",
    "docspace",
    "sdk"
  ],
  "license": "{{licenseName}}",
  "main": "./dist/index.js",
  "typings": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
{{#supportsES6}}
  "module": "./dist/esm/index.js",
  "sideEffects": false,
{{/supportsES6}}
  "scripts": {
  {{#supportsES6}}
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc",
    "build:esm": "tsc --project tsconfig.esm.json",
  {{/supportsES6}}
  {{^supportsES6}}
    "build": "tsc",
  {{/supportsES6}}
    "prepare": "npm run build"
  },
  "dependencies": {
    "axios": "{{axiosVersion}}"
  },
  "devDependencies": {
    "@types/node": "12.11.5 - 12.20.42",
    "typescript": "^4.0 || ^5.0"
  }
}
