{
  "$schema": "./node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.19.0"
  },
  "generatorName": "my-typescript-axios",
  "inputSpec": "./json/api-docs.json",
  "outputDir": "typescript-sdk",
  "additionalProperties": {
    "packageName": "@maticonoffice/docspace-api-sdk",
    "packageVersion": "3.7.0",
    "licenseName": "Apache-2.0",
    "repositoryUrl": "https://github.com/MaticonOffice/docspace-api-sdk-typescript",
    "withSeparateModelsAndApi": true,
    "modelPackage": "models",
    "apiPackage": "api", 
    "axiosVersion": "1.13.5",
    "useSingleRequestParameter": true,
    "supportsES6": true
  }
}